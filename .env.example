# Copy this file to .env before running Docker Compose.
#
# Generate a stable master key:
#   openssl rand -base64 32
#
# Keep this value safe. Losing it makes encrypted provider credentials
# unrecoverable after a data-volume reset.
KEIROUTER_MASTER_KEY=

# Host port exposed by Docker Compose.
KEIROUTER_PORT=20180

# Set to true only for local-only containers. VPS/Coolify usually needs false
# because reverse proxies connect from outside the container loopback interface.
KEIROUTER_BIND_LOOPBACK_ONLY=false

# json is recommended for containers; text is nicer for local terminals.
KEIROUTER_LOG_FORMAT=json

# Only needed when using deploy/compose.postgres.yaml.
POSTGRES_PASSWORD=
